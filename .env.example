# === Server ===
PORT=3001
NODE_ENV=development

# === PostgreSQL ===
DATABASE_URL=postgresql://patzig:patzig_secret@localhost:5432/bautagesbericht

# === JWT ===
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# === Encryption (for stored secrets in DB) ===
ENCRYPTION_KEY=change-me-32-byte-hex-key-here!!

# === Default Admin (created on first run) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# === Client ===
VITE_API_URL=http://localhost:3001/api

# === FTP ===
# Lokale Entwicklung: leer lassen, dann nutzt docker-compose den lokalen
# FTP-Service ("ftp" / "ftpuser" / "ftppass" mit Daten aus ftp-seed/).
# Für Tests gegen den Hostinger-Server diese Werte setzen:
#   FTP_HOST=72.60.178.75
#   FTP_PORT=21
#   FTP_USER=testuser
#   FTP_PASSWORD=testpass
FTP_HOST=
FTP_PORT=
FTP_USER=
FTP_PASSWORD=
