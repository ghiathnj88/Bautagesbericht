{
  "name": "patzig-bautagesbericht",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test:server": "npm test --prefix server",
    "test:client": "npm test --prefix client",
    "test:unit": "npm run test:server && npm run test:client",
    "test:integration": "npm run test:integration --prefix server",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "stack:test:up": "docker compose -p bautagesbericht-test -f docker-compose.test.yml up --build -d",
    "stack:test:down": "docker compose -p bautagesbericht-test -f docker-compose.test.yml down -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghiathnj88/Bautagesbericht.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ghiathnj88/Bautagesbericht/issues"
  },
  "homepage": "https://github.com/ghiathnj88/Bautagesbericht#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
